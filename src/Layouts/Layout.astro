---
import RightSidebar from '@/components/RightSidebar.astro';
import "@/styles/base.css";
import "@/styles/custom.css";
import { ViewTransitions } from "astro:transitions";
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  headings?: { depth: number; slug: string; text: string }[];
  hideTOC?: boolean; // .astro ファイルから直接渡す場合
  frontmatter?: {
    title?: string;
    hideTOC?: boolean; // .md / .mdx のフロントマターから渡される場合
  };
}

const { title, headings = [], hideTOC, frontmatter } = Astro.props;

// タイトルの決定
const pageTitle = title || frontmatter?.title || "Ravin Theme";

const shouldHideTOC = hideTOC || frontmatter?.hideTOC || false;
const showSidebar = headings.length > 0 && !shouldHideTOC;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <ViewTransitions />
  </head>
  <body>
    <Header />
    <div class="layout-container">
      <main class="main-content">
        <slot />
      </main>

      {showSidebar && (
        <RightSidebar headings={headings} />
      )}
    </div>

    <Footer />
  </body>
</html>

<style>
.layout-container {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    gap: 2.5rem;
    align-items: flex-start;
    flex: 1;
    width: 100%;
    box-sizing: border-box;
  }

  .main-content {
    flex: 1;
    min-width: 0;
  }
</style>
