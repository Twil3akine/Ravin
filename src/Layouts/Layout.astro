---
// src/layouts/Layout.astro
import RightSidebar from '@/components/RightSidebar.astro';
// CSSのカスケード制御: base -> custom の順で読み込む
import "@/styles/base.css";
import "@/styles/custom.css";

interface Props {
  title?: string;
  headings?: { depth: number; slug: string; text: string }[];
  hideTOC?: boolean; // .astro ファイルから直接渡す場合
  frontmatter?: {
    title?: string;
    hideTOC?: boolean; // .md / .mdx のフロントマターから渡される場合
  };
}

const { title, headings = [], hideTOC, frontmatter } = Astro.props;

// タイトルの決定
const pageTitle = title || frontmatter?.title || "Ravin Theme";

// TOCの表示判定
// 1. headingsが1つ以上あるか
// 2. hideTOC が true に設定されていないか（Props または Frontmatter）
const shouldHideTOC = hideTOC || frontmatter?.hideTOC || false;
const showSidebar = headings.length > 0 && !shouldHideTOC;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="layout-container">
      <main class="main-content">
        <slot />
      </main>

      {/* 条件を満たした場合のみ RightSidebar をレンダリング */}
      {showSidebar && (
        <RightSidebar headings={headings} />
      )}
    </div>
  </body>
</html>

<style>
  .layout-container {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  .main-content {
    flex: 1;
    min-width: 0; /* Flexbox内でのテキストのはみ出しを防ぐ */
  }
</style>
