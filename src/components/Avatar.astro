---
interface Props {
  src?: string;
  alt?: string;
  initials?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { src, alt = 'Avatar', initials = '', size = 'md' } = Astro.props;
---

<div class:list={['ravin-avatar', size]}>
  {src ? (
    <img src={src} alt={alt} />
  ) : (
    <span class="initials">{initials.slice(0, 2).toUpperCase()}</span>
  )}
</div>

<style>
  .ravin-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: var(--theme-border);
    color: var(--theme-text);
    overflow: hidden;
    flex-shrink: 0;
  }

  /* サイズバリエーション */
  .sm { width: 32px; height: 32px; font-size: 0.8rem; }
  .md { width: 48px; height: 48px; font-size: 1.2rem; }
  .lg { width: 64px; height: 64px; font-size: 1.5rem; }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .initials {
    font-weight: 600;
    letter-spacing: 0.05em;
  }
</style>
