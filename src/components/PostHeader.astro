---
// src/components/PostHeader.astro
import FormattedDate from './FormattedDate.astro';
import Tag from './Tag.astro';

interface Props {
  title: string;
  date?: Date;
  tags?: string[]; // シンプルに文字列の配列を受け取る
}

const { title, date, tags = [] } = Astro.props;
---

<header class="post-header">
  <h1 class="title">{title}</h1>

  {(date || tags.length > 0) && (
    <div class="meta">
      {date && <FormattedDate date={date} />}

      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => (
            <Tag href={`/tags/${tag}`}>{tag}</Tag>
          ))}
        </div>
      )}
    </div>
  )}
</header>

<style>
  .post-header {
    margin-bottom: 3rem;
  }

  .title {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 2.25rem;
    line-height: 1.3;
    font-weight: 700;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--theme-border);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
