---
const siteTitle = "Ravin";
const navLinks = [
    { href: "/", label: "Home" },
    { href: "/demos/example", label: "Blog" },
    { href: "/components/button", label: "Docs" },
];
---

<header class="header">
    <div class="header-inner">
        <a href="/" class="site-title"
            >{siteTitle}<span class="accent">.</span></a
        >
        <nav class="nav">
            <ul class="nav-list">
                {
                    navLinks.map((link) => (
                        <li>
                            <a href={link.href} class="nav-link">
                                {link.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>
</header>

<style>
    .header {
        border-bottom: 1px solid var(--theme-border);
        background-color: var(--theme-bg);
    }

    .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem 2rem;
    }

    .site-title {
        font-size: 1.5rem;
        font-weight: 800;
        text-decoration: none;
        color: var(--theme-text);
        letter-spacing: -0.02em;
    }

    .site-title .accent {
        color: var(--theme-accent);
    }

    .nav-list {
        display: flex;
        gap: 1.5rem;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .nav-link {
        text-decoration: none;
        color: var(--theme-text);
        font-weight: 500;
        font-size: 0.95rem;
        opacity: 0.7;
        transition:
            opacity 0.2s ease,
            color 0.2s ease;
    }

    .nav-link:hover {
        opacity: 1;
        color: var(--theme-accent);
    }
</style>
