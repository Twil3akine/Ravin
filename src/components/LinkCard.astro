---
export interface Props {
    href: string;
}

const { href } = Astro.props;

// デフォルト値（取得できなかった時のフォールバック）
let title = href;
let description = "";
let image = "";
let domain = new URL(href).hostname;

try {
    // ビルド時に指定されたURLへアクセスしてHTMLを取得
    const response = await fetch(href);
    if (response.ok) {
        const html = await response.text();

        // 正規表現でOGPタグを軽量に抽出
        const titleMatch =
            html.match(
                /<meta[^>]*property="og:title"[^>]*content="([^"]*)"[^>]*>/i,
            ) || html.match(/<title>([^<]*)<\/title>/i);
        if (titleMatch) title = decodeHTMLEntities(titleMatch[1]);

        const descMatch =
            html.match(
                /<meta[^>]*property="og:description"[^>]*content="([^"]*)"[^>]*>/i,
            ) ||
            html.match(
                /<meta[^>]*name="description"[^>]*content="([^"]*)"[^>]*>/i,
            );
        if (descMatch) description = decodeHTMLEntities(descMatch[1]);

        const imgMatch = html.match(
            /<meta[^>]*property="og:image"[^>]*content="([^"]*)"[^>]*>/i,
        );
        if (imgMatch) image = imgMatch[1];
    }
} catch (error) {
    console.error(`LinkCard fetch failed for ${href}`);
}

// 簡易的なHTMLエンティティのデコード関数
function decodeHTMLEntities(text: string) {
    return text
        .replace(/&#x([0-9A-Fa-f]+);/g, (_, dec) =>
            String.fromCharCode(parseInt(dec, 16)),
        )
        .replace(/&#(\d+);/g, (_, dec) => String.fromCharCode(dec))
        .replace(/&amp;/g, "&")
        .replace(/&lt;/g, "<")
        .replace(/&gt;/g, ">")
        .replace(/&quot;/g, '"');
}
---

<a href={href} class="link-card" target="_blank" rel="noopener noreferrer">
    <div class="content">
        <div class="title">{title}</div>
        {description && <div class="description">{description}</div>}
        <div class="footer">
            <svg
                class="domain-icon"
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="10"></circle><line
                    x1="2"
                    y1="12"
                    x2="22"
                    y2="12"></line><path
                    d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                ></path></svg
            >
            <span class="domain">{domain}</span>
        </div>
    </div>
    {
        image && (
            <div class="thumbnail">
                <img src={image} alt={title} loading="lazy" />
            </div>
        )
    }
</a>

<style>
    .link-card {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        margin: 1.5rem 0;
        border: 1px solid var(--theme-border);
        border-radius: 8px;
        overflow: hidden;
        text-decoration: none;
        background-color: var(--theme-bg);
        color: var(--theme-text);
        transition: all 0.2s ease;
    }

    .link-card:hover {
        border-color: var(--theme-accent);
    }

    .content {
        display: flex;
        flex-direction: column;
        padding: 1.2rem;
        flex: 1;
        min-width: 0; /* テキストの省略表示に必須 */
    }

    .title {
        font-size: 1.05rem;
        font-weight: 600;
        line-height: 1.4;
        margin-bottom: 0.5rem;
        /* 2行で三点リーダー表示 */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .description {
        font-size: 0.85rem;
        color: var(--theme-text);
        opacity: 0.7;
        margin-bottom: 0.8rem;
        /* 1行で三点リーダー表示 */
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .footer {
        display: flex;
        align-items: center;
        margin-top: auto;
        font-size: 0.8rem;
        color: var(--theme-text);
        opacity: 0.6;
    }

    .domain-icon {
        margin-right: 0.4rem;
    }

    .thumbnail {
        width: 30%;
        max-width: 200px;
        flex-shrink: 0;
        border-left: 1px solid var(--theme-border);
    }

    .thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* スマホ表示時の調整（画像を上部に配置） */
    @media (max-width: 600px) {
        .link-card {
            flex-direction: column-reverse;
        }
        .thumbnail {
            width: 100%;
            max-width: none;
            height: 150px;
            border-left: none;
            border-bottom: 1px solid var(--theme-border);
        }
    }
</style>
