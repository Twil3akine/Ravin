---
import Layout from '@/layouts/Layout.astro';
import PostHeader from '@/components/PostHeader.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';

// `docs` コレクションからすべてのドキュメントを取得します
const allDocsPosts = await getCollection('docs');
---

<Layout 
  title="ドキュメント一覧"
  description="Ravinテーマの利用に関するドキュメントの一覧です。"
>
  <Breadcrumbs />

  <PostHeader
    title="ドキュメント一覧"
    tags={["Docs"]}
  />

  <p style="color: var(--theme-text-muted); margin-bottom: 3rem;">
    これは <code>src/content/docs/</code> に配置されたMarkdown/MDXファイルを自動で取得してリスト表示するページです。
  </p>

  <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem;">
    {allDocsPosts.map(post => (
      <PostCard 
        href={`/docs/${post.slug}`}
        title={post.data.title}
        description={post.data.description}
      />
    ))}
  </ul>
</Layout>
