---
import Layout from '@/layouts/Layout.astro';
import PostHeader from '@/components/PostHeader.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

// `docs` コレクションからすべてのドキュメントを取得します
const allDocsPosts = await getCollection('docs');
---

<Layout title="ドキュメント一覧 (Demo)">
  <Breadcrumbs />

  <PostHeader
    title="ドキュメント一覧 (Demo)"
    tags={["Demo", "Docs"]}
  />

  <p style="color: var(--theme-text-muted); margin-bottom: 3rem;">
    これは <code>src/content/docs/</code> に配置されたMarkdown/MDXファイルを自動で取得してリスト表示するデモです。
  </p>

  <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem;">
    {allDocsPosts.map(post => (
      <li>
        <a 
          href={`/docs/${post.slug}`} 
          style="display: block; padding: 1.2rem; border: 1px solid var(--theme-border); border-radius: 8px; text-decoration: none; color: var(--theme-text); transition: border-color 0.2s;"
          class="doc-link"
        >
          <div style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.25rem;">{post.data.title}</div>
          {post.data.description && <div style="font-size: 0.85rem; color: var(--theme-text-muted);">{post.data.description}</div>}
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .doc-link:hover {
    border-color: var(--theme-accent) !important;
    background-color: var(--theme-accent-bg);
  }
</style>
