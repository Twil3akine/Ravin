---
import Layout from '@/layouts/Layout.astro';
import PostHeader from '@/components/PostHeader.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

// `blog` コレクションからすべての記事を取得し、日付順にソートします
const allBlogPosts = await getCollection('blog');
const sortedPosts = allBlogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout 
  title="ブログ記事一覧" 
  description="Ravinテーマで構築されたブログ記事の一覧ページです。"
>
  <Breadcrumbs />

  <PostHeader
    title="ブログ記事一覧"
    tags={["Blog"]}
  />

  <p style="color: var(--theme-text-muted); margin-bottom: 3rem;">
    これは <code>src/content/blog/</code> に配置されたMarkdown/MDXファイルを自動で取得してリスト表示するページです。AstroのContent Collections機能を活用しています。
  </p>

  <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem;">
    {sortedPosts.map(post => (
      <li>
        <a 
          href={`/blog/${post.slug}`} 
          style="display: block; padding: 1.5rem; border: 1px solid var(--theme-border); border-radius: 8px; text-decoration: none; color: var(--theme-text); transition: border-color 0.2s;"
          class="post-link"
        >
          <div style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem;">{post.data.title}</div>
          <div style="font-size: 0.85rem; color: var(--theme-text-muted); margin-bottom: 0.75rem;">
            {new Date(post.data.date).toLocaleDateString('ja-JP')}
          </div>
          {post.data.description && <div style="font-size: 0.95rem; opacity: 0.8;">{post.data.description}</div>}
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .post-link:hover {
    border-color: var(--theme-accent) !important;
  }
</style>
