---
import Layout from "@/layouts/Layout.astro";
import NavCard from "@/components/NavCard.astro";
import PostHeader from "@/components/PostHeader.astro";
import Grid from "@/components/Grid.astro";
---

<Layout title="Components - Ravin Theme">
  <PostHeader title="Components" tags={["UI", "Design System"]} />

  <p style="color: var(--theme-text-muted); margin-bottom: 3rem;">
    Ravinで利用可能なすべてのコンポーネントのリストです。MDXやAstroファイル内で自由に組み合わせて使用できます。
  </p>

  <section style="margin-bottom: 4rem;">
    <h2 style="font-size: 1.5rem; margin-bottom: 1.5rem;">Base Components</h2>
    <Grid columns={3}>
      <NavCard href="/components/avatar" title="Avatar" />
      <NavCard href="/components/breadcrumbs" title="Breadcrumbs" />
      <NavCard href="/components/button" title="Button" />
      <NavCard href="/components/callout" title="Callout" />
      <NavCard href="/components/codeblock" title="CodeBlock" />
      <NavCard href="/components/featurecard" title="FeatureCard" />
      <NavCard href="/components/label" title="Label" />
      <NavCard href="/components/link" title="Link" />
      <NavCard href="/components/linkcard" title="LinkCard" />
      <NavCard href="/components/marker" title="Marker" />
      <NavCard href="/components/navcard" title="NavCard" />
      <NavCard href="/components/postcard" title="PostCard" />
      <NavCard href="/components/spoiler" title="Spoiler" />
      <NavCard href="/components/steps" title="Steps" />
      <NavCard href="/components/table" title="Table" />
      <NavCard href="/components/tabs" title="Tabs" />
      <NavCard href="/components/toc" title="TOC" />
      <NavCard href="/components/toggle" title="Toggle" />
    </Grid>
  </section>

  <section style="margin-bottom: 4rem;">
    <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">Composite Components</h2>
    <p style="color: var(--theme-text-muted); margin-bottom: 1.5rem; font-size: 0.95rem;">
      複数のコンポーネントを組み合わせて構築された、特定の機能を持つコンポーネントです。
    </p>
    <Grid columns={3}>
      <NavCard href="/components/postheader" title="PostHeader" />
      <NavCard href="/components/themetoggle" title="ThemeToggle" />
    </Grid>
  </section>

  <section>
    <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">Third-party Components</h2>
    <p style="color: var(--theme-text-muted); margin-bottom: 1.5rem; font-size: 0.95rem;">
      外部ライブラリと連携し、高度な機能を提供するコンポーネントです。
    </p>
    <Grid columns={3}>
      <NavCard href="/components/search" title="Search" />
    </Grid>
  </section>
</Layout>
