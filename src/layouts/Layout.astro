---
import RightSidebar from "@/components/RightSidebar.astro";
import "@/styles/base.css";
import "@/styles/custom.css";
import { ClientRouter } from "astro:transitions";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title?: string;
  headings?: { depth: number; slug: string; text: string }[];
  hideTOC?: boolean;
  frontmatter?: {
    title?: string;
    hideTOC?: boolean;
  };
}

const { title, headings = [], hideTOC, frontmatter } = Astro.props;

const pageTitle = title || frontmatter?.title || "Ravin Theme";
const shouldHideTOC = hideTOC || frontmatter?.hideTOC || false;
const showSidebar = headings.length > 0 && !shouldHideTOC;

const siteTitle = "Ravin";
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/demos/blog", label: "Blog" },
  { href: "/demos/docs", label: "Docs" },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <ClientRouter />

    <style>
      .layout-container {
        display: flex;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
        gap: 2.5rem;
        align-items: flex-start;
        flex: 1;
        width: 100%;
        box-sizing: border-box;
      }

      .main-content {
        flex: 1;
        min-width: 0;
      }
    </style>
  </head>
  <body>
    <Header siteTitle={siteTitle} navLinks={navLinks}>
      <a
        slot="actions"
        href="https://github.com/twil3akine/ravin"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
        >
      </a>
    </Header>

    <div class="layout-container">
      <main class="main-content">
        <slot />
      </main>

      {showSidebar && <RightSidebar headings={headings} />}
    </div>

    <Footer siteTitle={siteTitle} />
  </body>
</html>
